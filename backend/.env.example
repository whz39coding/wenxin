APP_NAME=WenXinClassics Backend
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true


MYSQL_HOST=
MYSQL_PORT=
MYSQL_USER=
MYSQL_PASSWORD=<your_password>
MYSQL_DATABASE=wenxin_classics_db


CHROMA_PERSIST_DIR=backend/data/chroma


JWT_SECRET_KEY=<your_jwt_secret_key>
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=600


OPENAI_API_KEY=<your_api_key>
OPENAI_API_URL= https://XXX
OPENAI_API_MODEL=XXX

LOCAL_EMBEDDING_MODEL = "BAAI/bge-small-zh-v1.5"
SEARCH_TOP_K = 3

LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

OCR_MAX_IMAGE_PIXELS = 4000000
OCR_MAX_IMAGE_WIDTH = 2000
OCR_MAX_IMAGE_HEIGHT = 2000
OCR_PDF_RENDER_SCALE = 1.8
OCR_PDF_MAX_PAGES = 80
